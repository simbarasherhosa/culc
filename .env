# ====== PRODUCTION CONFIGURATION ======

# OpenAI - YOU MUST ADD YOUR ACTUAL KEY HERE

# Database - Use SQLite for now (simpler)
DATABASE_URL=sqlite:////var/www/myflaskapp/taxcul_ai_backend/production.db

# Redis
REDIS_URL=redis://localhost:6379/0

# Flask Settings
DEBUG=false
HOST=0.0.0.0
PORT=5000
WORKERS=3
SECRET_KEY=change-this-to-a-real-secret-key

# CORS - Allow your frontend
ALLOWED_ORIGINS=https://taxcul.com, https://api.taxculapi.com

# OpenAI Embedding Model
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
USE_OPENAI_EMBEDDINGS=True